{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/projects/**",
        "function": "ogEvents",
        "region": "us-central1"
      },
      {
        "source": "/events/**",
        "function": "ogEvents",
        "region": "us-central1"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/projects/**",
        "headers": [{ "key": "Cache-Control", "value": "no-store" }]
      },
      {
        "source": "/events/**",
        "headers": [{ "key": "Cache-Control", "value": "no-store" }]
      },
      {
        "source": "**/*.@(js|css|woff2|woff|ttf)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  }
}